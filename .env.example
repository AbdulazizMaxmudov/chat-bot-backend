# Copy this file to .env and fill in the real values.
# Set these as environment variables in Railway dashboard.

# Azure AI Speech
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=your_azure_region
AZURE_TTS_VOICE_RU=ru-RU-SvetlanaNeural
AZURE_TTS_VOICE_UZ=uz-UZ-MadinaNeural
AZURE_TTS_RATE=+25%

# Google Gemini / Vertex AI
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=europe-west1
VERTEX_AI_API_KEY=
GOOGLE_CREDENTIALS_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# Telegram monitoring bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=

# PostgreSQL (Railway provides DATABASE_URL automatically)
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://user:password@host:5432/dbname
